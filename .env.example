# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_MODEL=openai:gpt-4.1-mini
DEFAULT_TEMPERATURE=0.0

# Database (overridden automatically in docker compose)
DATABASE_URL=postgresql+asyncpg://axolotl:axolotl@localhost:5432/axolotl
REDIS_URL=redis://localhost:6379/0

# ChromaDB (overridden automatically in docker compose)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# LangSmith (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=axolotl

# App
APP_ENV=development
API_PORT=8000
ADMIN_PORT=8080
