# Build stage
FROM node:22-alpine AS builder
WORKDIR /app
COPY admin_ui/package.json admin_ui/package-lock.json ./
RUN npm ci
COPY admin_ui/ ./
RUN npm run build

# Production stage
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY admin_ui/nginx.conf /etc/nginx/conf.d/default.conf
COPY docker/entrypoint-admin.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
EXPOSE 8080
ENTRYPOINT ["/entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
